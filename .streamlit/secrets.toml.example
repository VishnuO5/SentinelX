# .streamlit/secrets.toml.example
# ===================================
# Copy this file to .streamlit/secrets.toml (WITHOUT the .example suffix)
# and fill in a real key to enable live Groq LLM output in the AI
# Investigator and the reasoning trace. Without this, the app runs
# correctly in rule-based fallback mode -- this is optional, not required.
#
# Get a free key at: https://console.groq.com/keys
#
# LOCAL DEVELOPMENT:
#   Save this as .streamlit/secrets.toml in your project root.
#   (.streamlit/secrets.toml is already in .gitignore -- never commit it.)
#
# STREAMLIT CLOUD:
#   Go to your app -> Settings -> Secrets, and paste the same content
#   there instead. Streamlit Cloud injects it as st.secrets automatically
#   -- you do NOT need to set it as an environment variable separately.

GROQ_API_KEY = "gsk_your_real_key_here"